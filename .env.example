# Copy to .env (gitignored) and adjust. The backend loads this at startup
# (backend/app.py -> python-dotenv). Real shell env vars take precedence over .env.

# --- Inference (mock vs real model) ---
USE_MOCK=1                 # 1 = mock answers; 0 = call model_adapter.predict
MOCK_DELAY_S=0             # artificial mock latency (s); >0 to see the loading state

# --- Layer-2 guard: encoder classifiers (opt-in models via requirements-guard.txt) ---
GUARD_ENABLED=1
GUARD_TOXICITY_THRESHOLD=0.7
GUARD_INJECTION_THRESHOLD=0.8
GUARD_PII_THRESHOLD=0.6

# --- Layer-3 guard: Llama Guard via Ollama (dev) / vLLM (prod) ---
GUARD_LLM_ENABLED=1                       # ON by default; falls back + WARNS if unavailable
GUARD_LLM_URL=http://localhost:11434
GUARD_LLM_MODEL=llama-guard3:1b
GUARD_LLM_TIMEOUT=20                       # generous enough to survive a cold model load

# --- Chart detector (Task A, CLIP — optional, falls back to the heuristic) ---
# CHART_CLIP_MODEL=openai/clip-vit-base-patch32
# CHART_CLIP_THRESHOLD=0.5

# --- Server ---
PORT=5000
