# Copy to .env (gitignored) and adjust. The backend loads this at startup
# (backend/app.py -> python-dotenv). Real shell env vars take precedence over .env.

# --- Inference (mock vs real model) ---
USE_MOCK=1                 # 1 = mock answers; 0 = call model_adapter.predict
MOCK_DELAY_S=0             # artificial mock latency (s); >0 to see the loading state
MOCK_REVEAL=0             # 1 = mock returns the canned answer instead of a disclaimer

# --- Server / uploads ---
HOST=127.0.0.1           # bind address; compose overrides to 0.0.0.0 in the container
PORT=5000
FLASK_DEBUG=1            # 1 = Flask reloader/debug (local); compose sets 0 in the container
MAX_UPLOAD_MB=10          # reject larger uploads (keep in sync with frontend MAX_BYTES)
MIN_QUESTION_ALNUM=3      # min alphanumeric chars before a question counts as "real"

# --- Layer-2 guard: encoder classifiers (opt-in models via requirements-guard.txt) ---
GUARD_ENABLED=1
GUARD_TOXICITY_THRESHOLD=0.7
GUARD_INJECTION_THRESHOLD=0.8
GUARD_PII_THRESHOLD=0.6
GUARD_TOXICITY_MODEL=original
GUARD_INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection-v2

# --- Layer-3 guard: Llama Guard via Ollama (dev) / vLLM (prod) ---
GUARD_LLM_ENABLED=1                       # ON by default; falls back + WARNS if unavailable
GUARD_LLM_URL=http://localhost:11434      # vLLM/prod: http://guard:8000 (see docs/ARCHITECTURE.md)
GUARD_LLM_MODEL=llama-guard3:1b
GUARD_LLM_TIMEOUT=20                       # generous enough to survive a cold model load
# Production only: HF token for the gated meta-llama/Llama-Guard-3-1B weights vLLM pulls.
# HF_TOKEN=

# --- Chart detector (Task A): CLIP zero-shot + OCR "has data" gate ---
CHART_CLIP_MODEL=openai/clip-vit-base-patch32
CHART_CLIP_THRESHOLD=0.5                   # P(chart) >= this AND has numeric data -> chart
CHART_MIN_DATA_DIGITS=2                    # min numeric chars OCR must find
# Pixel-heuristic fallback (used when CLIP/torch is unavailable):
CHART_SAMPLE_SIZE=128
CHART_MIN_BACKGROUND_RATIO=0.18
CHART_MAX_DISTINCT_COLORS=48
# Tesseract OCR engine: leave blank to use PATH (Linux/containers). On Windows
# point at the binary, e.g.:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
